---
import Base from "~/layouts/base.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<Base title="blog - n3bula.lol" pageTitle="blog">
  <section>
    <h1>Blog</h1>
    <div class="content">
      <ul>
        {
          posts.map((post) => (
            <li>
              <a href={`/blog/${post.id}`} style="padding:0">
                {post.data.title}
              </a>
              <p style="padding:0">{post.data.description}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</Base>
